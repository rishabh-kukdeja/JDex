# Backend Environment Variables Template
# Copy this to .env and fill in your values

# Firebase Configuration (get from Firebase Console)
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=1:your_app_id:web:your_web_id
FIREBASE_MEASUREMENT_ID=G-YOUR_ID

# Gemini API Key (get from Google AI)
GEMINI_API_KEY=your_gemini_api_key_here

# Environment
NODE_ENV=development
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3001

# Optional: Firebase Admin SDK (for production token verification)
# FIREBASE_ADMIN_SDK_JSON={"type":"service_account",...}
